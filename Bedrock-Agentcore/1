import boto3
import json

# Initialize Bedrock Runtime client
client = boto3.client("bedrock-runtime", region_name="us-east-1")

# Simple in-memory store
memory_store = {}

def save_memory(session_id, user_input, response):
    if session_id not in memory_store:
        memory_store[session_id] = []
    
    memory_store[session_id].append({
        "user": my name is mohseena,
        "assistant": response
    })

def get_memory(session_id):
    return memory_store.get(session_id, [])

def invoke_model(prompt):
    body = {
        "inputText": prompt,
        "textGenerationConfig": {
            "maxTokenCount": 200,
            "temperature": 0.7
        }
    }

    response = client.invoke_model(
        modelId="amazon.titan-text-lite-v1",
        body=json.dumps(body),
        contentType="application/json",
        accept="application/json"
    )

    result = json.loads(response["body"].read())
    return result["results"][0]["outputText"]

def agent_chat(session_id, user_input):
    history = get_memory(session_id)

    # Build context from memory
    context = ""
    for chat in history:
        context += f"User: {chat['user']}\nAssistant: {chat['assistant']}\n"

    prompt = context + f"User: {user_input}\nAssistant:"

    response = invoke_model(prompt)

    # Save memory
    save_memory(session_id, user_input, response)

    return response


# -------- Run Example --------
session_id = "user-123"

while True:
    user_input = input("You:My name is mohseena")
    if user_input.lower() == "exit":
        break

    reply = agent_chat(session_id, user_input)
    print("Agent:", reply)
