class TestIAMHelper:

    def test_build_least_privilege_policy_structure(self):
        policy = build_least_privilege_policy(
            service_actions={
                "s3":              ["GetObject", "PutObject"],
                "medical-imaging": ["GetImageSet"],
            },
            resource_arns=["arn:aws:s3:::test-bucket/*"],
            sid="TestSid",
        )
        assert policy["Version"] == "2012-10-17"
        stmt = policy["Statement"][0]
        assert stmt["Effect"]   == "Allow"
        assert stmt["Sid"]      == "TestSid"
        assert "s3:GetObject"              in stmt["Action"]
        assert "s3:PutObject"              in stmt["Action"]
        assert "medical-imaging:GetImageSet" in stmt["Action"]
        assert stmt["Resource"]            == ["arn:aws:s3:::test-bucket/*"]

    def test_pretty_policy_is_valid_json(self):
        policy = build_least_privilege_policy(
            {"s3": ["GetObject"]}, ["arn:aws:s3:::bucket/*"]
        )
        pretty = pretty_policy(policy)
        reparsed = json.loads(pretty)
        assert reparsed["Version"] == "2012-10-17"

    def test_actions_sorted_alphabetically(self):
        policy = build_least_privilege_policy(
            {"s3": ["PutObject", "GetObject", "ListBucket"]},
            ["*"],
        )
        actions = policy["Statement"][0]["Action"]
        assert actions == sorted(actions)


