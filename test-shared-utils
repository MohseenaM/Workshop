class TestStructuredLogger:

    def test_info_emits_json(self, capsys):
        log = StructuredLogger("TestService", "TestWorkshop")
        log.info("Test message", key="value", count=42)
        captured = capsys.readouterr().out.strip()
        record = json.loads(captured)
        assert record["level"]   == "INFO"
        assert record["message"] == "Test message"
        assert record["key"]     == "value"
        assert record["count"]   == 42
        assert record["service"] == "TestService"

    def test_error_emits_json(self, capsys):
        log = StructuredLogger("TestService", "TestWorkshop")
        log.error("Something failed", error="timeout")
        captured = capsys.readouterr().out.strip()
        record = json.loads(captured)
        assert record["level"] == "ERROR"
        assert record["error"] == "timeout"

    def test_warning_emits_json(self, capsys):
        log = StructuredLogger("TestService", "TestWorkshop")
        log.warning("Watch out", detail="high latency")
        captured = capsys.readouterr().out.strip()
        record = json.loads(captured)
        assert record["level"]  == "WARNING"
        assert record["detail"] == "high latency"


