class TestS3Utils:

    def test_upload_and_download_bytes(self, s3_bucket):
        with mock_aws():
            data = b"Hello, HealthImaging!"
            result = upload_bytes("mock-report-bucket", "test/file.bin", data)
            assert result["bucket"] == "mock-report-bucket"
            assert result["key"]    == "test/file.bin"

    def test_upload_and_download_json(self, s3_bucket):
        with mock_aws():
            payload = {"workshop": 1, "service": "HealthImaging", "status": "ok"}
            upload_json("mock-report-bucket", "test/report.json", payload)
            retrieved = download_json("mock-report-bucket", "test/report.json")
            assert retrieved["workshop"] == 1
            assert retrieved["service"]  == "HealthImaging"

    def test_list_objects(self, s3_bucket):
        with mock_aws():
            upload_bytes("mock-report-bucket", "reports/a.json", b"{}")
            upload_bytes("mock-report-bucket", "reports/b.json", b"{}")
            objects = list_objects("mock-report-bucket", prefix="reports/")
            keys = [o["Key"] for o in objects]
            assert "reports/a.json" in keys
            assert "reports/b.json" in keys


