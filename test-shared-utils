# lambda_monitor decorator test
# ═════════════════════════════════════════════════════════════

class TestLambdaMonitorDecorator:

    def test_decorator_passes_through_return_value(self, aws_credentials):
        from shared.cloudwatch_logger import lambda_monitor
        with mock_aws():
            @lambda_monitor(workshop="TestW", operation="TestOp")
            def my_handler(event, context):
                return {"statusCode": 200}

            result = my_handler({"Records": []}, None)
            assert result == {"statusCode": 200}

    def test_decorator_re_raises_exception(self, aws_credentials):
        from shared.cloudwatch_logger import lambda_monitor
        with mock_aws():
            @lambda_monitor(workshop="TestW", operation="TestOpFail")
            def failing_handler(event, context):
                raise ValueError("intentional failure")

            with pytest.raises(ValueError, match="intentional failure"):
                failing_handler({}, None)
